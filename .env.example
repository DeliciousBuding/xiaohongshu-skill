# ============================================================
# xiaohongshu-skill 环境变量
# ============================================================
# 复制本文件为 .env 后按需修改：
#   cp .env.example .env
# ============================================================

# 代理地址，留空则不使用代理
XHS_PROXY=http://127.0.0.1:7890

# 无头模式：true 则无头运行，false 则显示浏览器窗口
XHS_HEADLESS=true
